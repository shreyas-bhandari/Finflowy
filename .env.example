# ─────────────────────────────────────────────────────────────────
#  FinFlowy — Environment Variables
#  Copy this file to .env and fill in values
#
#  Architecture: Database-per-Service (4 isolated MongoDB instances)
# ─────────────────────────────────────────────────────────────────

# Backend API
PORT=5000

# ── Database-per-Service URIs ─────────────────────────────────────
# DB 1: Auth Service  (Users)
AUTH_DB_URI=mongodb://127.0.0.1:27017/auth_finflowy

# DB 2: ML / Insights Service (Alert Logs) — used by ML_Service
MONGO_URI=mongodb://127.0.0.1:27018/ml_finflowy

# DB 3: Transaction Service
TRANSACTION_DB_URI=mongodb://127.0.0.1:27019/transaction_finflowy

# DB 4: Goal Service
GOAL_DB_URI=mongodb://127.0.0.1:27020/goal_finflowy

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret

# ── ML Service ────────────────────────────────────────────────────
ML_API_URL=http://ml-service:5001/api/ml

# ── Node environment ──────────────────────────────────────────────
NODE_ENV=development
